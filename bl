-- Чёрный список продуктов и контактов
CREATE TABLE IF NOT EXISTS public.blacklist_items (
  id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id     UUID NOT NULL REFERENCES public.profiles(id) ON DELETE CASCADE,
  item_name   TEXT NOT NULL,
  item_type   TEXT NOT NULL CHECK (item_type IN ('food', 'contact')),
  reason      TEXT,
  severity    INTEGER CHECK (severity BETWEEN 1 AND 5),
  added_date  DATE NOT NULL DEFAULT CURRENT_DATE,
  notes       TEXT,
  created_at  TIMESTAMPTZ DEFAULT now()
);

ALTER TABLE public.blacklist_items ENABLE ROW LEVEL SECURITY;

CREATE POLICY "blacklist: own data" ON public.blacklist_items
  FOR ALL USING (auth.uid() = user_id);

CREATE INDEX IF NOT EXISTS idx_blacklist_user ON public.blacklist_items(user_id);
